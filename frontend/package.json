{
  "name": "video-converter-app",
  "version": "2.5.12",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\"",
    "prebuild": "rm -rf dist && mkdir dist && cp public/index.html dist/index.html && cp public/favicon.ico dist/favicon.ico",
    "build:css": "tailwindcss -i src/styles/tailwind.css -o dist/bundle.css --minify",
    "build:js": "esbuild src/app.ts --bundle --outfile=dist/bundle.js --sourcemap --external:*.css",
    "build": "pnpm run prebuild && pnpm run build:css && pnpm run build:js",
    "watch:css": "tailwindcss -i src/styles/tailwind.css -o dist/bundle.css --watch",
    "watch:js": "esbuild src/app.ts --bundle --outfile=dist/bundle.js --sourcemap --external:*.css --watch",
    "dev": "pnpm run prebuild && concurrently \"pnpm:watch:css\" \"pnpm:watch:js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.6.0",
  "devDependencies": {
    "@tailwindcss/cli": "4.3.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.13.1",
    "autoprefixer": "10.5.0",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
